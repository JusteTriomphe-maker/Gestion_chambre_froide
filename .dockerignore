# ignore local dependencies and generated files
node_modules
vendor
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
.env
.git

# ignore generated build artifacts
public/build
public/hot

# ignore local tools, logs, docs, and workspace temp folders
*.log
*.md
latest_laravel_log_tail.txt

# ignore other large workspace directories not needed for production build
temp-laravel
design-system
docs
tests
"database stock_entries migration./"
